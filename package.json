{
  "name": "stellar-flip",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "frontend",
    "docs"
  ],
  "scripts": {
    "dev": "pnpm --parallel --filter frontend --filter docs dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:docs": "pnpm --filter docs dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm --filter frontend typecheck && pnpm --filter docs typecheck"
  }
}